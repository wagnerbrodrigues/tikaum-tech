@rendermode InteractiveServer
@implements IDisposable
@inject BackupService BackupService
@inject AvisoSistemaService AvisoSistemaService
@inject ISnackbar Snackbar

@* Substitui o BackupWarning (toast que sobrepunha conteúdo): banner no fluxo do documento,
   entre topbar e conteúdo (TIKAUM_SPEC.md §6). Ilha interativa própria pelo mesmo motivo do
   InteractiveProviders — o MainLayout ao redor é estático e o [×] precisa de circuito vivo.
   O fechar é temporário de propósito: o componente é recriado na próxima navegação e o alerta
   volta enquanto a condição persistir (nunca silenciar permanentemente um problema real). *@

@if (AlgumVisivel)
{
    <div class="backup-banner-area">
        @if (_mostrarRestore && !_fechouRestore)
        {
            <div class="backup-alert backup-alert--warning">
                <MudIcon Icon="@Icons.Material.Filled.SettingsBackupRestore" Class="backup-alert__icon" aria-hidden="true" />
                <span class="backup-alert__text">
                    Restauração de backup pendente. Reinicie o sistema (feche e abra o TikaumTech)
                    para completar a restauração.
                </span>
                <a href="/backup" class="backup-alert__link">Ver detalhes →</a>
                <span class="backup-alert__close" title="Fechar aviso" @onclick="() => _fechouRestore = true">✕</span>
            </div>
        }
        @if (_mostrarCpfsDuplicados && !_fechouCpfsDuplicados)
        {
            <div class="backup-alert backup-alert--warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="backup-alert__icon" aria-hidden="true" />
                <span class="backup-alert__text">
                    @AvisoSistemaService.CpfsDuplicados.Count CPF(s) duplicado(s) na base impedem a
                    proteção contra CPF repetido: @string.Join(" · ", AvisoSistemaService.CpfsDuplicados).
                    Corrija em Clientes (edite um dos dois) e reinicie o sistema para ativar.
                </span>
                <a href="/pessoas" class="backup-alert__link">Ver clientes →</a>
                <span class="backup-alert__close" title="Fechar aviso" @onclick="() => _fechouCpfsDuplicados = true">✕</span>
            </div>
        }
        @if (_mostrarPenDrive && !_fechouPenDrive)
        {
            <div class="backup-alert backup-alert--danger">
                <MudIcon Icon="@Icons.Material.Filled.Usb" Class="backup-alert__icon" aria-hidden="true" />
                <span class="backup-alert__text">
                    @if (string.IsNullOrWhiteSpace(_volumeConfigurado))
                    {
                        <text>Pen drive de backup não configurado. Conecte um pen drive e selecione o volume na tela de Backup.</text>
                    }
                    else
                    {
                        <text>Pen drive de backup não encontrado. Conecte o volume "@_volumeConfigurado" ou configure um volume diferente.</text>
                    }
                </span>
                <a href="/backup" class="backup-alert__link">Configurar backup →</a>
                <span class="backup-alert__close" title="Fechar aviso" @onclick="() => _fechouPenDrive = true">✕</span>
            </div>
        }
        @if (_mostrarDriveErro && !_fechouDriveErro)
        {
            <div class="backup-alert backup-alert--danger">
                <MudIcon Icon="@Icons.Material.Filled.CloudOff" Class="backup-alert__icon" aria-hidden="true" />
                <span class="backup-alert__text">
                    Falha no último backup do Google Drive. Verifique a conexão com a conta.
                </span>
                <a href="/backup" class="backup-alert__link">Ver detalhes →</a>
                <span class="backup-alert__close" title="Fechar aviso" @onclick="() => _fechouDriveErro = true">✕</span>
            </div>
        }
        @if (_mostrarDrive && !_fechouDrive)
        {
            <div class="backup-alert backup-alert--warning">
                <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Class="backup-alert__icon" aria-hidden="true" />
                <span class="backup-alert__text">
                    Backup no Google Drive não configurado. Conecte sua conta para backup automático na nuvem.
                </span>
                <a href="/backup" class="backup-alert__link">Conectar Google Drive →</a>
                <span class="backup-alert__close" title="Fechar aviso" @onclick="() => _fechouDrive = true">✕</span>
            </div>
        }
    </div>
}

@code {
    private bool _mostrarPenDrive;
    private bool _mostrarDrive;
    private bool _mostrarDriveErro;
    private bool _mostrarRestore;
    private bool _mostrarCpfsDuplicados;
    private bool _fechouPenDrive;
    private bool _fechouDrive;
    private bool _fechouDriveErro;
    private bool _fechouRestore;
    private bool _fechouCpfsDuplicados;
    private string _volumeConfigurado = "";
    private Timer? _timer;

    private bool AlgumVisivel =>
        (_mostrarPenDrive && !_fechouPenDrive) ||
        (_mostrarDrive && !_fechouDrive) ||
        (_mostrarDriveErro && !_fechouDriveErro) ||
        (_mostrarRestore && !_fechouRestore) ||
        (_mostrarCpfsDuplicados && !_fechouCpfsDuplicados);

    protected override void OnInitialized()
    {
        Atualizar();
        _timer = new Timer(_ => InvokeAsync(() =>
        {
            Atualizar();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        // Toast único pós-restauração: o startup que aplicou o restore gravou
        // restore_done.json; o primeiro banner renderizado depois disso avisa e consome.
        var concluido = BackupService.LerRestoreConcluidoInfo();
        if (concluido is not null)
        {
            Snackbar.Add($"Banco restaurado com sucesso de {concluido.Origem} ({concluido.Backup}).",
                Severity.Success);
            BackupService.LimparRestoreConcluidoInfo();
        }
    }

    private void Atualizar()
    {
        _volumeConfigurado = BackupService.CarregarConfig().PenDriveVolumeName;
        _mostrarPenDrive = !BackupService.PenDriveConectado;
        _mostrarDrive = !BackupService.GoogleDriveConfigurado;
        _mostrarDriveErro = BackupService.GoogleDriveConfigurado && BackupService.GoogleDriveComErro;
        _mostrarRestore = BackupService.RestorePendente;
        _mostrarCpfsDuplicados = AvisoSistemaService.CpfsDuplicados.Count > 0;
    }

    public void Dispose() => _timer?.Dispose();
}
