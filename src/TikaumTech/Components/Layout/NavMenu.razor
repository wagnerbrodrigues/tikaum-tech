   que estava em MainLayout.razor, Rodada 12). *@
<nav class="tk-nav">
    <NavLink href="/" Match="NavLinkMatch.All">
        <MudIcon Icon="@Icons.Material.Filled.Dashboard" /><span>Dashboard</span>
    </NavLink>
    <NavLink href="/pessoas">
        <MudIcon Icon="@Icons.Material.Filled.People" /><span>Clientes</span>
    </NavLink>
    <NavLink href="/produtos">
        <MudIcon Icon="@Icons.Material.Filled.Inventory2" /><span>Produtos</span>
    </NavLink>
    <NavLink href="/servicos">
        <MudIcon Icon="@Icons.Material.Filled.ContentCut" /><span>Serviços</span>
    </NavLink>
    <NavLink href="/vendas">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" /><span>Vendas</span>
    </NavLink>
    <NavLink href="/relatorios">
        <MudIcon Icon="@Icons.Material.Filled.Assessment" /><span>Relatórios</span>
    </NavLink>

