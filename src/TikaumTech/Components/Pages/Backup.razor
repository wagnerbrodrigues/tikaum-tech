@page "/backup"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BackupService BackupService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Backup — Tikaum-Tech</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Class="page-title">Backup</MudText>

<!-- Status geral -->
<MudGrid Class="mb-3">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Usb"
                         Color="@(_penDriveConectado ? Color.Success : Color.Error)" />
                <MudText Typo="Typo.subtitle1">Pen Drive</MudText>
            </MudStack>

            @if (!_penDriveConfigurado)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Nenhum volume configurado. Selecione abaixo.
                </MudAlert>
            }
            else if (!_penDriveConectado)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    Volume "<strong>@_config.PenDriveVolumeName</strong>" não encontrado.
                    Conecte o pen drive.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Dense="true">
                    Conectado: <strong>@_config.PenDriveVolumeName</strong>
                </MudAlert>
            }

            <MudText Typo="Typo.body2" Class="mt-2">
                Último backup:
                @if (_status.PenDrive.UltimoOk.HasValue)
                {
                    <strong>@_status.PenDrive.UltimoOk.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
                else
                {
                    <span style="color:var(--mud-palette-text-secondary)">nunca realizado</span>
                }
            </MudText>

            @if (_status.PenDrive.Status == "erro")
            {
                <MudText Color="Color.Error" Typo="Typo.caption">
                    Erro: @_status.PenDrive.MensagemErro
                </MudText>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Backup"
                       Disabled="@(!_penDriveConectado || _fazendoBackup)"
                       OnClick="FazerBackupPenDriveAsync"
                       Class="mt-3" FullWidth="true">
                @if (_fazendoBackup)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                }
                Fazer backup agora
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Cloud"
                         Color="@(_gdriveConectado ? Color.Success : Color.Default)" />
                <MudText Typo="Typo.subtitle1">Google Drive</MudText>
            </MudStack>

            @if (!_gdriveCredencial)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Falta o arquivo de credenciais do Google. Siga as instruções abaixo
                    (uma única vez) e depois clique em Conectar.
                </MudAlert>
                <MudText Typo="Typo.body2" Class="mt-2" Style="color:var(--color-text-secondary)">
                    1. Acesse <code>console.cloud.google.com</code> logado como
                    <strong>@_config.GoogleDriveAccountEmail</strong> e crie um projeto (ex.: "TikaumTech").<br />
                    2. Em "APIs e serviços", ative a <strong>Google Drive API</strong>.<br />
                    3. Em "Tela de permissão OAuth", configure como Externo e adicione
                    <strong>@_config.GoogleDriveAccountEmail</strong> como usuário de teste.<br />
                    4. Em "Credenciais", crie um <strong>ID do cliente OAuth</strong> do tipo
                    "Aplicativo para computador" e baixe o JSON.<br />
                    5. Salve o arquivo como <code>@BackupService.CaminhoCredenciaisGoogle</code>.
                </MudText>
                <MudText Typo="Typo.caption" Class="mt-2 d-block" Style="color:var(--color-text-muted)">
                    A senha da conta Google nunca é digitada nem armazenada no sistema — o Google
                    não permite acesso por senha via aplicativo; a autorização é feita uma única
                    vez no navegador e o token resultante fica criptografado em disco.
                </MudText>
            }
            else if (!_gdriveConectado)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Credenciais encontradas. Clique em <strong>Conectar</strong> — o navegador vai
                    abrir para autorizar com a conta <strong>@_config.GoogleDriveAccountEmail</strong>
                    (uma única vez).
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Dense="true">
                    Conectado: <strong>@(_config.GoogleDriveEmailConectado.Length > 0
                        ? _config.GoogleDriveEmailConectado : _config.GoogleDriveAccountEmail)</strong>
                </MudAlert>
            }

            <MudText Typo="Typo.body2" Class="mt-2">
                Último backup:
                @if (_status.GoogleDrive.UltimoOk.HasValue)
                {
                    <strong>@_status.GoogleDrive.UltimoOk.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
                else
                {
                    <span style="color:var(--mud-palette-text-secondary)">nunca realizado</span>
                }
            </MudText>

            @if (_status.GoogleDrive.Status == "erro")
            {
                <MudText Color="Color.Error" Typo="Typo.caption">
                    Erro: @_status.GoogleDrive.MensagemErro
                </MudText>
            }

            @if (!_gdriveConectado)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Login"
                           Disabled="@(!_gdriveCredencial || _gdriveOcupado)"
                           OnClick="ConectarGoogleDriveAsync"
                           Class="mt-3" FullWidth="true">
                    @if (_gdriveOcupado)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    }
                    Conectar Google Drive
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Backup"
                           Disabled="_gdriveOcupado"
                           OnClick="FazerBackupGoogleDriveAsync"
                           Class="mt-3" FullWidth="true">
                    @if (_gdriveOcupado)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    }
                    Fazer backup agora
                </MudButton>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               Disabled="_gdriveOcupado"
                               OnClick="TestarGoogleDriveAsync">
                        Testar conexão
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.LinkOff"
                               Disabled="_gdriveOcupado"
                               OnClick="DesconectarGoogleDrive">
                        Desconectar
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Seleção de pen drive -->
<MudPaper Class="pa-4 mb-3" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-3">Configurar Pen Drive</MudText>

    @if (_unidadesDisponiveis.Count == 0)
    {
        <MudAlert Severity="Severity.Warning">
            Nenhuma unidade removível detectada. Conecte um pen drive e clique em Atualizar.
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.body2" Class="mb-2">
            Selecione o pen drive que deve receber os backups:
        </MudText>
        <MudRadioGroup T="string" @bind-Value="_volumeSelecionado">
            @foreach (var drive in _unidadesDisponiveis)
            {
                <MudRadio T="string" Value="@BackupService.NomeVolume(drive)" Color="Color.Primary">
                    <MudText>
                        <strong>@BackupService.NomeVolume(drive)</strong>
                        — @drive.Name
                        (@FormatBytes(drive.AvailableFreeSpace) livre de @FormatBytes(drive.TotalSize))
                    </MudText>
                </MudRadio>
            }
        </MudRadioGroup>

        <MudStack Row="true" Spacing="2" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                       Disabled="@string.IsNullOrWhiteSpace(_volumeSelecionado)"
                       OnClick="SalvarPenDrive">
                Salvar seleção
            </MudButton>
        </MudStack>
    }

    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="AtualizarUnidades" Class="mt-3">
        Atualizar unidades
    </MudButton>
</MudPaper>

<!-- Restaurar Backup (TIKAUM_SPEC.md §9 — decisão de 2026-07-11) -->
<MudPaper Class="pa-4 mb-3" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-2">Restaurar Backup</MudText>

    @if (_restorePendente)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            Restauração pendente: <strong>@(_restoreInfo?.Backup ?? "backup selecionado")</strong>
            (origem: @(_restoreInfo?.Origem ?? "—")).
            <strong>Reinicie o sistema</strong> (feche e abra o TikaumTech) para completar a restauração.
        </MudAlert>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Cancel"
                   OnClick="CancelarRestore">
            Cancelar restauração pendente
        </MudButton>
    }
    else
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">
            <strong>ATENÇÃO:</strong> restaurar um backup substituirá todos os dados atuais.
            Esta ação não pode ser desfeita. Recomendamos fazer um backup do estado atual
            antes de continuar.
        </MudAlert>

        <MudStack Row="true" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Backup"
                       Disabled="_restoreOcupado"
                       OnClick="BackupAntesDeRestaurarAsync">
                Fazer backup agora antes de restaurar
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Cloud"
                       Disabled="@(_restoreOcupado || !_gdriveConectado)"
                       OnClick="ListarBackupsDriveAsync">
                Listar backups do Google Drive
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Usb"
                       Disabled="@(_restoreOcupado || !_penDriveConectado)"
                       OnClick="ListarBackupsPenDriveAsync">
                Listar backups do pen drive
            </MudButton>
        </MudStack>

        @if (_restoreOcupado)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-1" />
            <MudText Typo="Typo.caption">@_restoreStatus</MudText>
        }
        else if (_backupsDisponiveis is not null)
        {
            @if (_backupsDisponiveis.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Nenhum backup encontrado em @_origemListada.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-2">
                    Backups disponíveis em <strong>@_origemListada</strong> (do mais recente
                    para o mais antigo):
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Style="overflow-x:auto">
                    <thead>
                        <tr>
                            <th>Arquivo</th>
                            <th style="width:150px">Data</th>
                            <th style="width:110px;text-align:right">Tamanho</th>
                            <th style="width:130px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var backup in _backupsDisponiveis)
                        {
                            <tr>
                                <td class="tk-mono">@backup.Nome</td>
                                <td>@(backup.Modificado?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td style="text-align:right">
                                    @(backup.TamanhoBytes is long tamanho ? FormatBytes(tamanho) : "—")
                                </td>
                                <td style="text-align:right">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.SettingsBackupRestore"
                                               OnClick="@(() => ConfirmarRestoreAsync(backup))">
                                        Restaurar
                                    </MudButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        }
    }
</MudPaper>

<!-- Informações -->
<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-2">Como funciona o backup</MudText>
    <MudList T="string" Dense="true">
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            Um arquivo por dia — rodar novamente no mesmo dia sobrescreve, nunca duplica.
        </MudListItem>
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            Retenção de <strong>@_config.RetencaoDias dias</strong> por destino — pen drive e
            Google Drive contam separadamente (arquivos mais antigos são removidos
            automaticamente após cada backup bem-sucedido).
        </MudListItem>
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            No Google Drive os arquivos ficam na pasta <code>TikaumBackup</code>; o acesso usa
            somente o escopo mínimo (o app só enxerga arquivos criados por ele) e o token fica
            criptografado em <code>config/</code>.
        </MudListItem>
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            O arquivo gerado é uma cópia íntegra do banco SQLite via <code>VACUUM INTO</code>,
            que pode ser restaurada diretamente.
        </MudListItem>
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            Os arquivos ficam em <code>[PenDrive]\TikaumBackup\tikaum_YYYY-MM-DD.db</code>.
        </MudListItem>
        <MudListItem T="string" Icon="@Icons.Material.Filled.FiberManualRecord">
            A restauração é aplicada no próximo início do sistema; o banco substituído fica
            preservado como <code>tikaum_pre_restore_[data].db</code> na pasta <code>data/</code>.
        </MudListItem>
    </MudList>
</MudPaper>

@code {
    private BackupConfig _config = new();
    private BackupStatus _status = new();
    private List<DriveInfo> _unidadesDisponiveis = [];
    private string _volumeSelecionado = "";
    private bool _penDriveConfigurado;
    private bool _penDriveConectado;
    private bool _fazendoBackup;
    private bool _gdriveCredencial;
    private bool _gdriveConectado;
    private bool _gdriveOcupado;

    // Restore (TIKAUM_SPEC.md §9)
    private bool _restorePendente;
    private RestoreInfo? _restoreInfo;
    private bool _restoreOcupado;
    private string _restoreStatus = "";
    private List<BackupDisponivel>? _backupsDisponiveis;
    private string _origemListada = "";
    private bool _origemEhDrive;

    protected override void OnInitialized()
    {
        Recarregar();
    }

    private void Recarregar()
    {
        _config = BackupService.CarregarConfig();
        _status = BackupService.CarregarStatus();
        _penDriveConfigurado = BackupService.PenDriveConfigurado;
        _penDriveConectado = BackupService.PenDriveConectado;
        _unidadesDisponiveis = BackupService.ObterUnidadesRemoviveis();
        _volumeSelecionado = _config.PenDriveVolumeName;
        _gdriveCredencial = BackupService.GoogleDriveCredencialPresente;
        _gdriveConectado = BackupService.GoogleDriveConfigurado;
        _restorePendente = BackupService.RestorePendente;
        _restoreInfo = BackupService.LerRestorePendenteInfo();
    }

    private async Task ConectarGoogleDriveAsync()
    {
        _gdriveOcupado = true;
        var (ok, mensagem) = await BackupService.ConectarGoogleDriveAsync();
        Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);
        Recarregar();
        _gdriveOcupado = false;
    }

    private async Task TestarGoogleDriveAsync()
    {
        _gdriveOcupado = true;
        var (ok, mensagem) = await BackupService.TestarConexaoGoogleDriveAsync();
        Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);
        _gdriveOcupado = false;
    }

    private async Task FazerBackupGoogleDriveAsync()
    {
        _gdriveOcupado = true;
        var (ok, mensagem) = await BackupService.FazerBackupGoogleDriveAsync();
        _status = BackupService.CarregarStatus();
        Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);
        _gdriveOcupado = false;
    }

    private void DesconectarGoogleDrive()
    {
        var (ok, mensagem) = BackupService.DesconectarGoogleDrive();
        Snackbar.Add(mensagem, ok ? Severity.Info : Severity.Warning);
        Recarregar();
    }

    private void AtualizarUnidades() => Recarregar();

    private async Task FazerBackupPenDriveAsync()
    {
        _fazendoBackup = true;
        var (ok, mensagem) = await BackupService.FazerBackupPenDriveAsync();
        _status = BackupService.CarregarStatus();
        if (ok)
            Snackbar.Add(mensagem, Severity.Success);
        else
            Snackbar.Add(mensagem, Severity.Error);
        _fazendoBackup = false;
    }

    private void SalvarPenDrive()
    {
        if (string.IsNullOrWhiteSpace(_volumeSelecionado)) return;
        BackupService.SalvarVolumePenDrive(_volumeSelecionado);
        Recarregar();
        Snackbar.Add($"Pen drive configurado: {_volumeSelecionado}", Severity.Success);
    }

    // --- Restore ---

    private async Task BackupAntesDeRestaurarAsync()
    {
        _restoreOcupado = true;
        _restoreStatus = "Fazendo backup do estado atual...";
        var algumDestino = false;

        if (BackupService.PenDriveConectado)
        {
            algumDestino = true;
            var (ok, mensagem) = await BackupService.FazerBackupPenDriveAsync();
            Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);
        }
        if (BackupService.GoogleDriveConfigurado)
        {
            algumDestino = true;
            var (ok, mensagem) = await BackupService.FazerBackupGoogleDriveAsync();
            Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);
        }
        if (!algumDestino)
            Snackbar.Add("Nenhum destino de backup disponível — conecte o pen drive ou o Google Drive.",
                Severity.Warning);

        _status = BackupService.CarregarStatus();
        _restoreOcupado = false;
    }

    private async Task ListarBackupsDriveAsync()
    {
        _restoreOcupado = true;
        _restoreStatus = "Listando backups do Google Drive...";
        StateHasChanged();

        var (ok, mensagem, backups) = await BackupService.ListarBackupsGoogleDriveAsync();
        if (!ok) Snackbar.Add(mensagem, Severity.Error);
        _backupsDisponiveis = ok ? backups : null;
        _origemListada = "Google Drive";
        _origemEhDrive = true;
        _restoreOcupado = false;
    }

    private async Task ListarBackupsPenDriveAsync()
    {
        _restoreOcupado = true;
        _restoreStatus = "Listando backups do pen drive...";
        StateHasChanged();

        var (ok, mensagem, backups) = await BackupService.ListarBackupsPenDriveAsync();
        if (!ok) Snackbar.Add(mensagem, Severity.Error);
        _backupsDisponiveis = ok ? backups : null;
        _origemListada = "pen drive";
        _origemEhDrive = false;
        _restoreOcupado = false;
    }

    private async Task ConfirmarRestoreAsync(BackupDisponivel backup)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"ATENÇÃO: restaurar o backup {backup.Nome} ({_origemListada}) " +
                              "substituirá todos os dados atuais. Esta ação não pode ser desfeita. " +
                              "Recomendamos fazer um backup do estado atual antes de continuar. Continuar?" },
            { x => x.ConfirmText, "Restaurar" },
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Restaurar backup", parameters);
        if ((await dialog.Result)!.Canceled) return;

        _restoreOcupado = true;
        _restoreStatus = _origemEhDrive
            ? $"Baixando {backup.Nome} do Google Drive..."
            : $"Copiando {backup.Nome} do pen drive...";
        StateHasChanged();

        var (ok, mensagem) = _origemEhDrive
            ? await BackupService.BaixarBackupGoogleDriveAsync(backup.Id)
            : await BackupService.CopiarBackupPenDriveAsync(backup.Id);
        Snackbar.Add(mensagem, ok ? Severity.Success : Severity.Error);

        _restoreOcupado = false;
        if (ok)
        {
            _backupsDisponiveis = null;
            Recarregar();
        }
    }

    private void CancelarRestore()
    {
        var (ok, mensagem) = BackupService.CancelarRestorePendente();
        Snackbar.Add(mensagem, ok ? Severity.Info : Severity.Warning);
        Recarregar();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:F1} GB";
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        return $"{bytes / 1024.0:F0} KB";
    }
}
