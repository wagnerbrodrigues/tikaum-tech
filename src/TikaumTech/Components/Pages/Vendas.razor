@page "/vendas/nova"
@attribute [Authorize]
@rendermode InteractiveServer
@* PessoaId passado via query string a partir do detalhe da pessoa *@

@inject PessoaService PessoaService
@inject ProdutoService ProdutoService
@inject ServicoService ServicoService
@inject VendaService VendaService
@inject UsuarioService UsuarioService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Nova Venda — Tikaum-Tech</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Class="page-title">Nova Venda</MudText>

<!-- Pessoa + Data (venda não registra hora — TIKAUM_SPEC.md §5) -->
<MudPaper Class="pa-4 mb-3" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="4">
            @if (!_vendaAvulsa)
            {
                <MudAutocomplete T="Pessoa"
                                 Label="Cliente"
                                 SearchFunc="SearchPessoaAsync"
                                 Value="_pessoaSelecionada"
                                 ValueChanged="PessoaSelecionadaAsync"
                                 ToStringFunc="@(p => p?.Nome ?? "")"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 FullWidth="true">
                    <ItemTemplate Context="p">
                        @if (p.Id == NovoClienteId)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Color="Color.Secondary">Cadastrar "<strong>@p.Nome</strong>" como novo cliente</MudText>
                            </MudStack>
                        }
                        else
                        {
                            @p.Nome
                            @if (p.Identificacao.Length > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block tk-mono">
                                    @p.Identificacao
                                </MudText>
                            }
                        }
                    </ItemTemplate>
                </MudAutocomplete>
            }
            else
            {
                <MudText Color="Color.Secondary" Class="mt-4">Venda avulsa (sem cadastro de cliente)</MudText>
            }
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSwitch T="bool" @bind-Value="_vendaAvulsa"
                       Label="Avulsa" Color="Color.Secondary" />
        </MudItem>
        <MudItem xs="6" md="2">
            @* Quem fez a venda — pré-carregado com o primeiro usuário ≠ admin (spec §6) *@
            <MudSelect T="string" @bind-Value="_usuarioVenda" Label="Usuário">
                @foreach (var usuario in _usuarios)
                {
                    <MudSelectItem T="string" Value="@usuario">@usuario</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            @* Editable: permite digitar a data direto (além do picker). Sem DateMask de
               propósito — o combo Editable+Mask do MudDatePicker perde a posição do caret
               (teclas inserem sempre no início; verificado em navegador real). *@
            <MudDatePicker @bind-Date="_dataVenda" Label="Data" DateFormat="dd/MM/yyyy"
                           Editable="true" Placeholder="dd/mm/aaaa" />
        </MudItem>
    </MudGrid>
    <MudTextField @bind-Value="_observacao" Label="Observação (opcional)" Lines="2" MaxLength="500" Class="mt-3" />
</MudPaper>

<!-- Adicionar Item -->
<MudPaper Class="pa-4 mb-3" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-2">Adicionar Item</MudText>
    <MudTabs @bind-ActivePanelIndex="_abaAtiva" Elevation="0" Rounded="true" ApplyEffectsToContainer="true">

        @* Serviço vem antes de Produto — é o carro-chefe do estúdio (pedido de 2026-07-08) *@
        <MudTabPanel Text="Serviço">
            <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Class="mt-3">
                <MudAutocomplete T="Servico"
                                 Label="Buscar serviço..."
                                 SearchFunc="SearchServicoAsync"
                                 @bind-Value="_servicoSelecionado"
                                 ToStringFunc="@(s => s?.Nome ?? "")"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 Style="flex:1" />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.AddShoppingCart"
                           Disabled="_servicoSelecionado is null"
                           OnClick="AdicionarServico">Adicionar</MudButton>
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Produto">
            <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Class="mt-3">
                <MudAutocomplete T="Produto"
                                 Label="Buscar produto..."
                                 SearchFunc="SearchProdutoAsync"
                                 @bind-Value="_produtoSelecionado"
                                 ToStringFunc="@(p => p?.Nome ?? "")"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 Style="flex:1" />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.AddShoppingCart"
                           Disabled="_produtoSelecionado is null"
                           OnClick="AdicionarProduto">Adicionar</MudButton>
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Item Livre">
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_descricaoLivre" Label="Descrição do item" MaxLength="200" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudNumericField T="decimal" @bind-Value="_precoLivre" Label="Preço (R$)"
                                     Min="0" Format="F2" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" md="3" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.AddShoppingCart"
                               Disabled="@string.IsNullOrWhiteSpace(_descricaoLivre)"
                               OnClick="AdicionarItemLivre" FullWidth="true">Adicionar</MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>
</MudPaper>

<!-- Carrinho -->
@if (_carrinho.Count > 0)
{
    <MudPaper Class="pa-4 mb-3" Elevation="1">
        <MudText Typo="Typo.subtitle1" Class="mb-2">
            Carrinho — @_carrinho.Count item(s)
        </MudText>
        <MudSimpleTable Dense="true" Hover="true" Style="overflow-x:auto">
            <thead>
                <tr>
                    <th>Item</th>
                    <th style="width:110px;text-align:center">Qtd</th>
                    <th style="width:130px;text-align:right">Preço unit. (R$)</th>
                    <th style="width:100px;text-align:right">Total (R$)</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _carrinho)
                {
                    <tr>
                        <td>
                            @item.Descricao
                            @if (item.EhItemLivre)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">livre</MudChip>
                            }
                        </td>
                        <td>
                            <MudNumericField T="decimal"
                                             Value="item.Quantidade"
                                             ValueChanged="@(v => { item.Quantidade = v; StateHasChanged(); })"
                                             Min="0.001m" Format="F3" HideSpinButtons="true"
                                             Style="width:90px" />
                        </td>
                        <td style="text-align:right">
                            <MudNumericField T="decimal"
                                             Value="item.ValorUnitario"
                                             ValueChanged="@(v => { item.ValorUnitario = v; StateHasChanged(); })"
                                             Min="0" Format="F2" HideSpinButtons="true"
                                             Style="width:110px" />
                        </td>
                        <td style="text-align:right;white-space:nowrap">
                            @item.ValorTotal.ToString("F2")
                        </td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RemoverItem(item))" />
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="font-weight:bold">
                    <td colspan="3" style="text-align:right;padding-right:8px">TOTAL</td>
                    <td style="text-align:right">R$ @TotalVenda.ToString("F2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </MudSimpleTable>
    </MudPaper>
}

<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
    <MudButton Variant="Variant.Outlined"
               OnClick="@(() => Nav.NavigateTo("/"))">
        Cancelar
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Save"
               Disabled="@(_carrinho.Count == 0 || _salvando)"
               OnClick="SalvarVendaAsync">
        @if (_salvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
        Salvar Venda
    </MudButton>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? PessoaId { get; set; }

    private class ItemCarrinho
    {
        public Guid Key { get; } = Guid.NewGuid();
        public Produto? Produto { get; set; }
        public Servico? Servico { get; set; }
        public string? DescricaoLivre { get; set; }
        public decimal Quantidade { get; set; } = 1;
        public decimal ValorUnitario { get; set; }
        public decimal ValorTotal => Math.Round(Quantidade * ValorUnitario, 2);
        public bool EhItemLivre => Produto is null && Servico is null;
        public string Descricao => Produto?.Nome ?? Servico?.Nome ?? DescricaoLivre ?? "";
    }

    // Estado geral
    private Pessoa? _pessoaSelecionada;
    private bool _vendaAvulsa;
    private DateTime? _dataVenda = DateTime.Today;
    private string? _observacao;
    private List<string> _usuarios = [];
    private string? _usuarioVenda;
    private bool _salvando;

    // Carrinho
    private readonly List<ItemCarrinho> _carrinho = [];

    // Aba de adicionar item
    private int _abaAtiva;
    private Produto? _produtoSelecionado;
    private Servico? _servicoSelecionado;
    private string _descricaoLivre = "";
    private decimal _precoLivre;

    private decimal TotalVenda => _carrinho.Sum(i => i.ValorTotal);

    protected override async Task OnInitializedAsync()
    {
        if (PessoaId.HasValue)
            _pessoaSelecionada = await PessoaService.ObterAsync(PessoaId.Value);

        // Pré-seleciona o primeiro usuário que não seja 'admin' (na prática, 'tikaum');
        // se só existir 'admin', usa ele mesmo. Ordem alfabética = mesma da tela /usuarios.
        _usuarios = [.. (await UsuarioService.ListarAsync())
            .Select(u => u.UserName ?? "")
            .Where(nome => nome.Length > 0)];
        _usuarioVenda =
            _usuarios.FirstOrDefault(u => !u.Equals("admin", StringComparison.OrdinalIgnoreCase))
            ?? _usuarios.FirstOrDefault();
    }

    // Autocomplete callbacks

    // Id sentinela do item "+ Cadastrar ... como novo cliente" — nunca colide com o banco
    // (Ids reais começam em 1).
    private const int NovoClienteId = -1;

    private async Task<IEnumerable<Pessoa>> SearchPessoaAsync(string value, CancellationToken ct)
    {
        var resultados = await PessoaService.ListarAsync(value);
        // Busca sem resultado: o próprio dropdown oferece o cadastro rápido com o texto digitado
        if (resultados.Count == 0 && !string.IsNullOrWhiteSpace(value))
            return [new Pessoa { Id = NovoClienteId, Nome = value.Trim() }];
        return resultados;
    }

    private async Task PessoaSelecionadaAsync(Pessoa? pessoa)
    {
        if (pessoa is null || pessoa.Id != NovoClienteId)
        {
            _pessoaSelecionada = pessoa;
            return;
        }

        // Item de cadastro rápido: abre o mesmo dialog de /pessoas com o nome já preenchido.
        // O carrinho não é tocado — só o campo de cliente muda; cancelar volta sem seleção.
        _pessoaSelecionada = null;
        var parameters = new DialogParameters<PessoaDialog>
        {
            { x => x.Pessoa, new Pessoa { Nome = pessoa.Nome } },
        };
        var dialog = await DialogService.ShowAsync<PessoaDialog>("Novo Cliente", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Pessoa criada })
            _pessoaSelecionada = criada;
    }

    private async Task<IEnumerable<Produto>> SearchProdutoAsync(string value, CancellationToken ct) =>
        await ProdutoService.ListarAsync(value, apenasAtivos: true);

    private async Task<IEnumerable<Servico>> SearchServicoAsync(string value, CancellationToken ct) =>
        await ServicoService.ListarAsync(value, apenasAtivos: true);

    private void AdicionarProduto()
    {
        if (_produtoSelecionado is null) return;
        _carrinho.Add(new ItemCarrinho
        {
            Produto = _produtoSelecionado,
            ValorUnitario = _produtoSelecionado.PrecoPadrao
        });
        _produtoSelecionado = null;
    }

    private void AdicionarServico()
    {
        if (_servicoSelecionado is null) return;
        _carrinho.Add(new ItemCarrinho
        {
            Servico = _servicoSelecionado,
            ValorUnitario = _servicoSelecionado.PrecoPadrao
        });
        _servicoSelecionado = null;
    }

    private void AdicionarItemLivre()
    {
        if (string.IsNullOrWhiteSpace(_descricaoLivre)) return;
        _carrinho.Add(new ItemCarrinho
        {
            DescricaoLivre = _descricaoLivre.Trim(),
            ValorUnitario = _precoLivre
        });
        _descricaoLivre = "";
        _precoLivre = 0;
    }

    private void RemoverItem(ItemCarrinho item) => _carrinho.Remove(item);

    private async Task SalvarVendaAsync()
    {
        if (_carrinho.Count == 0) return;
        if (!_vendaAvulsa && _pessoaSelecionada is null)
        {
            Snackbar.Add("Selecione o cliente ou marque a venda como avulsa.", Severity.Warning);
            return;
        }
        _salvando = true;
        try
        {
            var dto = new NovaVendaDto(
                PessoaId: _vendaAvulsa ? null : _pessoaSelecionada?.Id,
                DataHora: (_dataVenda ?? DateTime.Today).Date,
                Observacao: _observacao,
                Usuario: _usuarioVenda,
                Itens: [.. _carrinho.Select(i => new NovoItemVendaDto(
                    ProdutoId: i.Produto?.Id,
                    ServicoId: i.Servico?.Id,
                    DescricaoLivre: i.DescricaoLivre,
                    Quantidade: i.Quantidade,
                    ValorUnitario: i.ValorUnitario))]
            );

            await VendaService.CriarAsync(dto);
            Snackbar.Add("Venda registrada com sucesso!", Severity.Success);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao salvar venda: {ex.Message}", Severity.Error);
            _salvando = false;
        }
    }
}
